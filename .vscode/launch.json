{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug LplKernel (xmake + QEMU + GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/linux/x86_64/debug/lpl.kernel",
            "cwd": "${workspaceFolder}",
            "args": [],
            "stopAtEntry": false,
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "targetArchitecture": "x86",
            "setupCommands": [
                {
                    "description": "Set architecture to i386",
                    "text": "set architecture i386",
                    "ignoreFailures": false
                },
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Intel disassembly",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "Load kernel symbols (built with -g)",
                    "text": "file ${workspaceFolder}/build/linux/x86_64/debug/lpl.kernel",
                    "ignoreFailures": false
                },
                {
                    "description": "Connect to the QEMU gdb stub (-s = tcp::1234)",
                    "text": "target remote localhost:1234",
                    "ignoreFailures": false
                },
                {
                    "description": "Break at kernel_main",
                    "text": "break kernel_main",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Debug: xmake build + QEMU (-s -S)",
            "postDebugTask": "Kill QEMU",
            "logging": {
                "engineLogging": false
            }
        }
    ],
    "inputs": [
        {
            "id": "profile",
            "type": "pickString",
            "description": "Kernel profile",
            "options": [
                { "label": "client (graphics, realtime)", "value": "--realtime=y --graphics=y" },
                { "label": "server (tty/console)", "value": "--realtime=n --graphics=n" }
            ],
            "default": "--realtime=y --graphics=y"
        },
        {
            "id": "keyboard",
            "type": "pickString",
            "description": "Keyboard layout",
            "options": ["us", "fr"],
            "default": "us"
        },
        {
            "id": "smoke",
            "type": "pickString",
            "description": "Smoke / diagnostic battery",
            "options": ["y", "n"],
            "default": "y"
        }
    ]
}
