KERNEL_ARCH_CFLAGS=
KERNEL_ARCH_CPPFLAGS=
KERNEL_ARCH_LDFLAGS=
KERNEL_ARCH_LIBS=

# Multiboot version selection (1 or 2)
MULTIBOOT_VERSION?=1

ifeq ($(MULTIBOOT_VERSION),2)
BOOT_OBJECT=$(ARCHDIR)/boot/boot2.o
KERNEL_ARCH_CPPFLAGS+=-DMULTIBOOT_VERSION=2
else
BOOT_OBJECT=$(ARCHDIR)/boot/boot.o
KERNEL_ARCH_CPPFLAGS+=-DMULTIBOOT_VERSION=1
endif

# Kernel mode selection:
#   REALTIME_MODE=1  -> client VR build: Free-List PMM (O(1) deterministic)
#   REALTIME_MODE=0  -> server build:    Buddy Allocator PMM (to be implemented)
REALTIME_MODE?=1

ifeq ($(REALTIME_MODE),1)
KERNEL_ARCH_CPPFLAGS+=-DLPL_KERNEL_REAL_TIME_MODE
endif

# Optional APIC periodic-mode smoke test toggle.
APIC_SMOKE_TEST_PERIODIC_MODE?=0
ifeq ($(APIC_SMOKE_TEST_PERIODIC_MODE),1)
KERNEL_ARCH_CPPFLAGS+=-DKERNEL_SMOKE_TEST_ENABLE_APIC_PERIODIC_MODE=1u
endif

# Default keyboard layout (us = QWERTY, fr = AZERTY):
#   us -> United States QWERTY (default)
#   fr -> French AZERTY
# Override at build time with `./build.sh --azerty` / `--qwerty`.
# The layout can also be switched at runtime via the `layout` console command.
KEYBOARD_LAYOUT?=us
ifeq ($(KEYBOARD_LAYOUT),fr)
KERNEL_ARCH_CPPFLAGS+=-DLPL_KERNEL_KEYBOARD_LAYOUT_AZERTY
endif

KERNEL_ARCH_OBJS=\
$(BOOT_OBJECT) \
$(ARCHDIR)/boot/init_array.o \
$(ARCHDIR)/boot/helpers/multiboot_info_helper.o \
$(ARCHDIR)/cpu/gdt.o \
$(ARCHDIR)/cpu/tss.o \
$(ARCHDIR)/cpu/idt.o \
$(ARCHDIR)/cpu/gdt_load.o \
$(ARCHDIR)/cpu/tss_load.o \
$(ARCHDIR)/cpu/idt_load.o \
$(ARCHDIR)/cpu/ring3.o \
$(ARCHDIR)/cpu/isr.o \
$(ARCHDIR)/cpu/isr_stubs.o \
$(ARCHDIR)/cpu/clock.o \
$(ARCHDIR)/cpu/irq.o \
$(ARCHDIR)/cpu/exception.o \
$(ARCHDIR)/cpu/helpers/gdt_helper.o \
$(ARCHDIR)/cpu/paging.o \
$(ARCHDIR)/cpu/paging_asm.o \
$(ARCHDIR)/cpu/pmm.o \
$(ARCHDIR)/cpu/acpi.o \
$(ARCHDIR)/cpu/pic.o \
$(ARCHDIR)/cpu/pit.o \
$(ARCHDIR)/cpu/apic.o \
$(ARCHDIR)/cpu/apic_timer.o \
$(ARCHDIR)/cpu/cpu_topology.o \
$(ARCHDIR)/cpu/ioapic.o \
$(ARCHDIR)/cpu/ap_bootstrap.o \
$(ARCHDIR)/cpu/ap_startup.o \
$(ARCHDIR)/cpu/ap_trampoline.o \
$(ARCHDIR)/cpu/ap_trampoline_blob.o \
$(ARCHDIR)/cpu/apic_ipi.o \
$(ARCHDIR)/cpu/pci.o \
$(ARCHDIR)/cpu/helpers/clock_helper.o \
$(ARCHDIR)/cpu/helpers/cpu_topology_helper.o \
$(ARCHDIR)/cpu/helpers/acpi_helper.o \
$(ARCHDIR)/cpu/helpers/ioapic_helper.o \
$(ARCHDIR)/cpu/helpers/apic_timer_helper.o \
$(ARCHDIR)/cpu/helpers/ap_startup_helper.o \
$(ARCHDIR)/cpu/helpers/pci_helper.o \
$(ARCHDIR)/drivers/tty.o \
