# i386 architecture configuration for libengine (freestanding LplPlugin).
#
# Determinism (HARD contract): all float math goes through SSE (-msse2
# -mfpmath=sse) with contraction disabled (-ffp-contract=off) so results are
# IEEE-exact and bit-identical to the Linux/xmake oracle, which is built with
# the matching -ffp-contract=off. Authoritative state is Fixed32 (integer);
# these flags only fix the non-authoritative float paths and the compile-time
# CORDIC table folding.
# -fno-math-errno: __builtin_sqrt etc. fold to a bare sqrtsd instead of a libm
# call with errno bookkeeping. Freestanding has no libm/errno, and the errno
# side effect is itself non-deterministic — dropping it is both necessary to
# link and correct for the determinism contract (the returned value is the same
# IEEE-exact sqrtsd result either way).
ARCH_CXXFLAGS=-msse2 -mfpmath=sse -ffp-contract=off -fno-math-errno
ARCH_CPPFLAGS=

# LplPlugin engine sources compiled into libengine.a (paths relative to
# LPLPLUGIN_ROOT). P0 scope: the deterministic math core. Header-only modules
# (Vec/Mat/Quat/Morton) need no object here. core/src/Log.cpp is deferred until
# the kernel console logging sink exists (see lpl/std/cstdio.hpp).
ARCH_ENGINE_SRCS=\
math/src/Cordic.cpp \
math/src/Statistics.cpp \
math/src/Simd.cpp \
