# i386: nothing architecture-specific yet. The runtime's only machine
# dependencies (kmalloc/kfree, cli/hlt) are resolved at link time from libk,
# not compiled in here. This file exists so libkxx follows the same
# arch/$(HOSTARCH)/make.config contract as libc and kernel.
ARCH_CXXFLAGS=
ARCH_CPPFLAGS=
ARCH_OBJS=
