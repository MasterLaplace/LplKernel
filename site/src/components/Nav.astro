---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Normalised current path, used to flag the active link for assistive tech.
const here = Astro.url.pathname.replace(/\/$/, "") || base;
const links = [
  { href: `${base}/`, label: "Home" },
  { href: `${base}/#demo`, label: "Live demo" },
  { href: `${base}/projects`, label: "Projects" },
  { href: `${base}/roadmap`, label: "Roadmap" },
  { href: `${base}/book`, label: "Book" },
  { href: `${base}/blog`, label: "Blog / Papers" },
  { href: "https://github.com/MasterLaplace", label: "GitHub", external: true },
];

// A link is "current" only for real page routes (the /#demo anchor is not a page).
const isCurrent = (href: string) =>
  !href.includes("#") && !href.startsWith("http") && href.replace(/\/$/, "") === here;
---

<header class="sticky top-0 z-40 backdrop-blur border-b border-lpl-border bg-lpl-bg/70">
  <nav class="mx-auto max-w-6xl flex items-center justify-between px-4 py-3" aria-label="Main">
    <a href={`${base}/`} class="font-mono font-bold tracking-tight text-lpl-text">
      <span class="text-lpl-accent" aria-hidden="true">λ</span> Laplace<span class="text-lpl-muted"
        >.project</span
      >
      <span class="sr-only">— home</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-5 text-sm">
      {
        links.map((l) => (
          <li>
            <a
              class="text-lpl-muted hover:text-lpl-accent transition-colors"
              href={l.href}
              aria-current={isCurrent(l.href) ? "page" : undefined}
              {...l.external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
            >
              {l.label}
              {l.external && (
                <>
                  <span aria-hidden="true">↗</span>
                  <span class="sr-only">(opens in a new tab)</span>
                </>
              )}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      class="md:hidden inline-flex items-center justify-center w-9 h-9 border border-lpl-border text-lpl-text hover:text-lpl-accent hover:border-lpl-accent transition-colors"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <svg id="nav-icon-open" aria-hidden="true" focusable="false" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg id="nav-icon-close" aria-hidden="true" focusable="false" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="18" y1="6" x2="6" y2="18"></line>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <nav id="nav-mobile" class="hidden md:hidden border-t border-lpl-border bg-lpl-bg/95" aria-label="Mobile">
    <ul>
      {
        links.map((l) => (
          <li class="border-b border-lpl-border/60 last:border-b-0">
            <a
              class="block px-4 py-3 text-sm text-lpl-muted hover:text-lpl-accent hover:bg-white/5 transition-colors"
              href={l.href}
              aria-current={isCurrent(l.href) ? "page" : undefined}
              {...l.external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
            >
              {l.label}
              {l.external && (
                <>
                  <span aria-hidden="true">↗</span>
                  <span class="sr-only">(opens in a new tab)</span>
                </>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-mobile");
  const iconOpen = document.getElementById("nav-icon-open");
  const iconClose = document.getElementById("nav-icon-close");

  function setOpen(open: boolean) {
    if (!menu || !toggle) return;
    menu.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
  }

  toggle?.addEventListener("click", () => {
    setOpen(menu?.classList.contains("hidden") ?? false);
  });

  // Close after tapping a link.
  menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
</script>
